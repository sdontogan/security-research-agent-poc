---
import { siteConfig } from '../config';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Contact Sarah D about senior data science, machine learning, applied AI, enterprise knowledge, learning technology, and AI security opportunities."
>
  <section class="section">
    <div class="container-wide contact-grid">
      <div class="contact-intro">
        <p class="eyebrow page-kicker">Contact / Start a conversation</p>
        <h1>Let’s talk about AI that has to work in the real world.</h1>
        <p class="page-lede">
          I’m interested in senior roles and collaborations across applied
          machine learning, production AI, enterprise knowledge and learning
          systems, AI security, and threat intelligence. Send a note here
          without exposing either of our email addresses publicly.
        </p>
        <div class="contact-list" aria-label="Professional profiles">
          <a
            class="contact-link"
            href={siteConfig.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            ><span>LinkedIn</span><strong>Professional profile</strong><span
              aria-hidden="true">↗</span
            ></a
          >
          <a
            class="contact-link"
            href={siteConfig.github}
            target="_blank"
            rel="noopener noreferrer"
            ><span>GitHub</span><strong>GitHub portfolio</strong><span
              aria-hidden="true">↗</span
            ></a
          >
          <a class="contact-link" href="/recruiter"
            ><span>Overview</span><strong>One-minute recruiter brief</strong
            ><span aria-hidden="true">→</span></a
          >
        </div>
      </div>

      <form class="contact-form" data-contact-form>
        <div class="contact-form-heading">
          <p class="eyebrow">Private contact form</p>
          <h2>Send Sarah a message</h2>
          <p>
            Your message is sent directly to Sarah’s inbox. Contact details are
            used only to reply and are not published on this website.
          </p>
        </div>

        <div class="contact-field-row">
          <div class="contact-field">
            <label for="contact-name">Your name</label>
            <input
              id="contact-name"
              name="name"
              type="text"
              autocomplete="name"
              minlength="2"
              maxlength="80"
              required
            />
          </div>
          <div class="contact-field">
            <label for="contact-email">Your email</label>
            <input
              id="contact-email"
              name="email"
              type="email"
              autocomplete="email"
              maxlength="254"
              required
            />
          </div>
        </div>

        <div class="contact-field">
          <label for="contact-topic">What would you like to discuss?</label>
          <select id="contact-topic" name="topic" required>
            <option value="">Choose a topic</option>
            <option value="hiring">Hiring opportunity</option>
            <option value="collaboration">Project collaboration</option>
            <option value="speaking">Speaking or writing</option>
            <option value="other">Something else</option>
          </select>
        </div>

        <div class="contact-field">
          <label for="contact-message">Message</label>
          <textarea
            id="contact-message"
            name="message"
            rows="7"
            minlength="20"
            maxlength="2000"
            required
            placeholder="A short introduction and what you’d like to discuss…"
          ></textarea>
          <small
            >20–2,000 characters. Please do not include confidential
            information.</small
          >
        </div>

        <div class="contact-honeypot" aria-hidden="true">
          <label for="contact-company-website">Company website</label>
          <input
            id="contact-company-website"
            name="companyWebsite"
            type="text"
            tabindex="-1"
            autocomplete="off"
          />
        </div>

        <div class="contact-verification" data-contact-verification>
          <span>Loading secure verification…</span>
        </div>

        <div class="contact-submit-row">
          <p class="contact-privacy">
            Protected by Cloudflare Turnstile. No marketing list or analytics
            tracking.
          </p>
          <button class="button" type="submit" disabled data-contact-submit>
            Send message
          </button>
        </div>
        <p
          class="contact-status"
          role="status"
          aria-live="polite"
          data-contact-status
        >
        </p>
      </form>
    </div>
  </section>

  <script>
    interface TurnstileApi {
      render(
        container: HTMLElement,
        options: {
          sitekey: string;
          theme: 'auto';
          size: 'flexible';
          callback: (token: string) => void;
          'expired-callback': () => void;
          'error-callback': () => void;
        },
      ): string;
      reset(widgetId: string): void;
    }

    declare global {
      interface Window {
        turnstile?: TurnstileApi;
      }
    }

    const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
    const submit = document.querySelector<HTMLButtonElement>(
      '[data-contact-submit]',
    );
    const status = document.querySelector<HTMLElement>('[data-contact-status]');
    const verification = document.querySelector<HTMLElement>(
      '[data-contact-verification]',
    );
    const sitekey = '0x4AAAAAAD6xv5LO7IsDhRQJ';
    let turnstileToken = '';
    let widgetId = '';

    const updateSubmit = () => {
      if (submit) submit.disabled = !turnstileToken;
    };

    const setStatus = (message: string, kind: 'success' | 'error' | '') => {
      if (!status) return;
      status.textContent = message;
      status.dataset.kind = kind;
    };

    const loadTurnstile = async () => {
      await new Promise<void>((resolve, reject) => {
        if (window.turnstile) return resolve();
        const existing = document.querySelector<HTMLScriptElement>(
          'script[src^="https://challenges.cloudflare.com/turnstile/v0/api.js"]',
        );
        if (existing) {
          existing.addEventListener('load', () => resolve(), { once: true });
          existing.addEventListener(
            'error',
            () => reject(new Error('Verification failed to load')),
            { once: true },
          );
          return;
        }
        const script = document.createElement('script');
        script.src =
          'https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit';
        script.async = true;
        script.defer = true;
        script.onload = () => resolve();
        script.onerror = () => reject(new Error('Verification failed to load'));
        document.head.append(script);
      });
      if (!verification || !window.turnstile)
        throw new Error('Verification unavailable');
      verification.replaceChildren();
      widgetId = window.turnstile.render(verification, {
        sitekey,
        theme: 'auto',
        size: 'flexible',
        callback: (token) => {
          turnstileToken = token;
          if (status?.dataset.kind === 'error') setStatus('', '');
          updateSubmit();
        },
        'expired-callback': () => {
          turnstileToken = '';
          updateSubmit();
        },
        'error-callback': () => {
          turnstileToken = '';
          setStatus(
            'Verification failed. Please refresh and try again.',
            'error',
          );
          updateSubmit();
        },
      });
    };

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!turnstileToken || !submit || !form.reportValidity()) return;

      const data = new FormData(form);
      submit.disabled = true;
      submit.textContent = 'Sending…';
      setStatus('Sending your message securely…', '');

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          headers: {
            'content-type': 'application/json',
            accept: 'application/json',
          },
          body: JSON.stringify({
            name: data.get('name'),
            email: data.get('email'),
            topic: data.get('topic'),
            message: data.get('message'),
            companyWebsite: data.get('companyWebsite'),
            turnstileToken,
          }),
        });
        const result = (await response.json()) as {
          ok?: boolean;
          error?: string;
        };
        if (!response.ok || !result.ok) {
          throw new Error(result.error || 'Your message could not be sent.');
        }
        form.reset();
        setStatus(
          'Message sent. Thank you — Sarah will reply by email.',
          'success',
        );
      } catch (error) {
        setStatus(
          error instanceof Error
            ? error.message
            : 'Your message could not be sent. Please try again.',
          'error',
        );
      } finally {
        turnstileToken = '';
        submit.textContent = 'Send message';
        if (widgetId && window.turnstile) window.turnstile.reset(widgetId);
        updateSubmit();
      }
    });

    void loadTurnstile().catch(() => {
      if (verification)
        verification.textContent =
          'Secure verification is temporarily unavailable. Please use LinkedIn instead.';
      setStatus('The contact form is temporarily unavailable.', 'error');
    });
  </script>
</BaseLayout>
