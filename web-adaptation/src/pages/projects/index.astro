---
import { getCollection } from 'astro:content';
import CTA from '../../components/CTA.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout
  title="Projects"
  description="Selected applied-AI and machine-learning systems from Sarah D, including a live research agent and a production phishing-domain detection pipeline."
>
  <header class="page-hero">
    <div class="container-wide">
      <p class="eyebrow page-kicker">Projects / Selected work</p>
      <h1>Applied AI built for real-world use.</h1>
      <p class="page-lede">
        These projects show how I approach the full system: useful models,
        safeguards, production operations, and results that people can inspect
        and trust.
      </p>
    </div>
  </header>
  <section class="section">
    <div class="container-wide projects-list">
      {
        projects.map((project, index) => (
          <ProjectCard id={project.id} index={index + 1} {...project.data} />
        ))
      }
    </div>
  </section>
  <CTA
    eyebrow="A quick scan"
    title="Review the experience in under one minute."
    text="The recruiter overview connects these projects to my wider experience in production AI, enterprise learning, knowledge systems, and cybersecurity."
    primaryLabel="Recruiter overview"
    primaryHref="/recruiter"
    secondaryLabel="Download résumé"
    secondaryHref="/Sarah_D_Resume_2026.docx"
  />
</BaseLayout>
