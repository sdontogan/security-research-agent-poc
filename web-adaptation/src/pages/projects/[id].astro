---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ArchitectureDiagram from '../../components/ArchitectureDiagram.astro';
import CTA from '../../components/CTA.astro';
import DomainResearchDemo from '../../components/DomainResearchDemo.astro';
import PhishingDetectionVisual from '../../components/PhishingDetectionVisual.astro';
import ProjectTypeBadge from '../../components/ProjectTypeBadge.astro';
import SkillBadge from '../../components/SkillBadge.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout
  title={project.data.title}
  description={project.data.summary}
  type="article"
>
  <header class="case-hero">
    <div class="container-wide">
      <a class="back-link" href="/projects"
        ><span aria-hidden="true">←</span> Back to projects</a
      >
      <p class="eyebrow">{project.data.eyebrow}</p>
      <ProjectTypeBadge type={project.data.type} />
      <h1>{project.data.title}</h1>
      <div class="case-summary">
        <p>{project.data.summary}</p>
        <div class="case-meta">
          <span>{project.data.status}</span><strong>{project.data.meta}</strong>
        </div>
      </div>
      {
        project.data.type === 'demo' ? (
          <div class="project-hero-treatment project-demo-treatment">
            <p>{project.data.liveNote}</p>
            <div class="hero-actions">
              <a class="button" href="#live-demo">
                Try it now
              </a>
              {project.data.sourceUrl && (
                <a
                  class="button button-secondary"
                  href={project.data.sourceUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  View latest source on GitHub <span aria-hidden="true">↗</span>
                </a>
              )}
            </div>
          </div>
        ) : (
          <div class="project-hero-treatment project-case-study-treatment">
            <strong>Built at {project.data.company}</strong>
            <p>
              Proprietary production system—not publicly deployable. Described
              here from its architecture, measured results, and my role.
            </p>
            <a class="text-link" href="#results">
              Jump to results →
            </a>
          </div>
        )
      }
    </div>
  </header>

  {
    project.data.visual === 'phishing-detection' && (
      <section class="container-wide section-tight">
        <PhishingDetectionVisual />
      </section>
    )
  }

  {
    project.data.demo === 'domain-research' && (
      <section class="container-wide section-tight">
        <DomainResearchDemo />
      </section>
    )
  }

  {
    project.data.diagram && (
      <section class="container-wide section-tight">
        <ArchitectureDiagram type={project.data.diagram} />
      </section>
    )
  }

  <section class="section">
    <div class="container case-layout">
      <aside class="case-sidebar">
        <h2>Technology stack</h2>
        <div class="badge-list">
          {project.data.technologies.map((item) => <SkillBadge label={item} />)}
        </div>
      </aside>
      <div class="case-content">
        <article class="prose"><Content /></article>
        <section
          class:list={[
            'case-results',
            project.data.type === 'case-study' && 'case-results-featured',
          ]}
          id="results"
        >
          <h2>Results</h2>
          <ul>{project.data.results.map((result) => <li>{result}</li>)}</ul>
        </section>
        <section class="case-results">
          <h2>Key challenges</h2>
          <ul>
            {project.data.challenges.map((challenge) => <li>{challenge}</li>)}
          </ul>
        </section>
        <a
          class="back-link"
          href="/projects"
          style="margin-top: 3rem; margin-bottom: 0;"
          ><span aria-hidden="true">←</span> Back to all projects</a
        >
      </div>
    </div>
  </section>
  {
    project.data.type === 'case-study' ? (
      <CTA
        eyebrow="Case study / Discussion"
        title="Ask me about the engineering decisions."
        text="I can discuss my role, architecture, evaluation, safeguards, and operational tradeoffs without sharing proprietary implementation details."
        primaryLabel="Contact Sarah"
        primaryHref="/contact"
        secondaryLabel="Recruiter overview"
        secondaryHref="/recruiter"
      />
    ) : (
      <CTA
        eyebrow="Try the live demo"
        title="Research a public domain."
        text="The agent uses bounded, read-only sources and shows missing evidence instead of hiding it."
        primaryLabel="Try it now"
        primaryHref="#live-demo"
        secondaryLabel="Contact Sarah"
        secondaryHref="/contact"
      />
    )
  }
</BaseLayout>
