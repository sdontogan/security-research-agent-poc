---
import SkillBadge from './SkillBadge.astro';

interface Props {
  id: string;
  title: string;
  eyebrow: string;
  summary: string;
  technologies: string[];
  index?: number;
}

const { id, title, eyebrow, summary, technologies, index = 1 } = Astro.props;
---

<article class="project-card">
  <div class="project-card-top">
    <span class="project-index" aria-hidden="true">0{index}</span>
    <p class="eyebrow">{eyebrow}</p>
  </div>
  <h3><a href={`/projects/${id}`}>{title}</a></h3>
  <p>{summary}</p>
  <div class="badge-list" aria-label="Selected technologies">
    {
      technologies
        .slice(0, 4)
        .map((technology) => <SkillBadge label={technology} />)
    }
  </div>
  <a
    class="text-link"
    href={`/projects/${id}`}
    aria-label={`View project: ${title}`}
  >
    View project <span aria-hidden="true">↗</span>
  </a>
</article>
