---
import SkillBadge from './SkillBadge.astro';
import ProjectTypeBadge from './ProjectTypeBadge.astro';

interface Props {
  id: string;
  title: string;
  eyebrow: string;
  summary: string;
  type: 'demo' | 'case-study';
  technologies: string[];
  index?: number;
}

const {
  id,
  title,
  eyebrow,
  summary,
  type,
  technologies,
  index = 1,
} = Astro.props;
---

<article class="project-card">
  <div class="project-card-top">
    <span class="project-index" aria-hidden="true">0{index}</span>
    <div class="project-card-labels">
      <ProjectTypeBadge type={type} />
      <p class="eyebrow">{eyebrow}</p>
    </div>
  </div>
  <h3><a href={`/projects/${id}`}>{title}</a></h3>
  <p>{summary}</p>
  <div class="badge-list" aria-label="Selected technologies">
    {
      technologies
        .slice(0, 4)
        .map((technology) => <SkillBadge label={technology} />)
    }
  </div>
  <a
    class="text-link"
    href={`/projects/${id}`}
    aria-label={`${type === 'demo' ? 'Try live demo' : 'Read case study'}: ${title}`}
  >
    {type === 'demo' ? 'Try live demo' : 'Read case study'}
    <span aria-hidden="true">↗</span>
  </a>
</article>
